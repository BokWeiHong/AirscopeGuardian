[Unit]
Description=GloopieGuardian Device Hunter
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/pi/GloopieGuardian

# Required if your plugin interacts with your Django Database
Environment="DJANGO_SETTINGS_MODULE=config.settings"
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/home/pi/GloopieGuardian/app/tracker/saves/tracking.env

# 1. Start Monitor Mode
ExecStartPre=/usr/sbin/airmon-ng start ${TRACK_IFACE}

# 2. Run Trackerjacker (Using the venv Python directly, no 'source activate' needed)
ExecStart=/home/pi/GloopieGuardian/venv/bin/python /home/pi/GloopieGuardian/venv/bin/trackerjacker --track -m ${TRACK_MAC} -i ${TRACK_IFACE}mon --threshold 1 --channels-to-monitor ${TRACK_CHANNELS} --plugin /home/pi/GloopieGuardian/app/tracker/trigger_commands/gloopie-plugin.py

# 3. Clean up Monitor Mode when stopped
ExecStopPost=/usr/sbin/airmon-ng stop ${TRACK_IFACE}mon

RemainAfterExit=no
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target