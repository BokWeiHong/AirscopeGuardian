# ─────────────────────────────────────────────────────────────
# AirscopeGuardian environment variables
# Copy this file to .env and fill in values for your machine.
# .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=localhost
DB_PORT=5432

# External tool directories (only needed if not in the default location)
# WASMSHARK_DIR=/home/youruser/wasmshark

# Kismet credentials (optional — auto-read from kismet_httpd.conf if absent)
# KISMET_USER=kismetuser
# KISMET_PASS=kismetpassword
